# E-Ink Web Renderer Configuration Template
# Copy this file to '.env' and modify for your local setup.
# Any undefined variables will automatically fall back to their docker-compose/index.js defaults.

# The web page or dashboard URL you want to capture (e.g. your local React eInk dashboard)
TARGET_URL=https://example.com

# Cron schedule pattern for rendering interval (default: once per minute)
CRON_JOB=*/1 * * * *

# Maximum milliseconds to wait for page navigation and load
RENDERING_TIMEOUT=30000

# Delay in milliseconds to settle page rendering before taking screenshot
RENDERING_DELAY=1000

# Dimensions of simulated screen viewport
RENDERING_SCREEN_WIDTH=1200
RENDERING_SCREEN_HEIGHT=825

# Grayscale depth: 1 (binary B&W), 4 (16 gray shades), 8 (256 gray shades)
GRAYSCALE_DEPTH=8
